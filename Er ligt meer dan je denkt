let lang = 'nl';

function setLang(l, btn) {
  lang = l;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyLang();
}

function applyLang() {
  const L = T[lang];
  document.getElementById('header-title').textContent = L.pageTitle;
  document.getElementById('sit-time').textContent = L.sitTime;
  document.getElementById('sit-title').textContent = L.sitTitle;
  document.getElementById('sit-desc').textContent = L.sitDesc;
  document.getElementById('schap-title').textContent = L.schapTitle;
  document.getElementById('sub-pistolet').textContent = L.subPistolet;
  document.getElementById('sub-tijger').textContent = L.subTijger;
  document.getElementById('sub-kaiser').textContent = L.subKaiser;
  document.getElementById('sub-desem').textContent = L.subDesem;
  document.getElementById('next-ronde-text').textContent = L.nextRonde;
  document.getElementById('vraag-title').textContent = L.vraagTitle;
  document.getElementById('lbl-slecht').textContent = L.lblSlecht;
  document.getElementById('sub-slecht').textContent = L.subSlecht;
  document.getElementById('lbl-ok').textContent = L.lblOk;
  document.getElementById('sub-ok').textContent = L.subOk;
  document.getElementById('lbl-goed').textContent = L.lblGoed;
  document.getElementById('sub-goed').textContent = L.subGoed;
  document.getElementById('btn-opnieuw').textContent = L.opnieuw;
  if(L.lblVroeg) document.getElementById('lbl-vroeg').textContent = L.lblVroeg;
  if(L.subVroeg) document.getElementById('sub-vroeg').textContent = L.subVroeg;
}

function kies(type) {
  const L = T[lang];
  const r = L.results[type];
  document.querySelectorAll('.keuze-btn').forEach(b => b.className = 'keuze-btn');
  document.getElementById('btn-'+type).className = 'keuze-btn ' + (type==='goed'||type==='vroeg'?'selected-good':type==='ok'?'selected-ok':'selected-bad');
  const badge = document.getElementById('result-badge');
  badge.textContent = r.badge;
  badge.className = 'result-badge '+r.badgeClass;
  document.getElementById('result-title').textContent = r.title;
  document.getElementById('result-desc').textContent = r.desc;
  const chain = document.getElementById('result-chain');
  chain.innerHTML = `<div class="chain-title">${r.chainTitle}</div>`+r.chain.map(s=>`<div class="chain-step"><div class="chain-dot ${s.cls}">${s.icon}</div><span>${s.text}</span></div>`).join('');
  const tip = document.getElementById('result-tip');
  tip.textContent = r.tip;
  tip.className = 'result-tip '+r.tipClass;
  showScreen('screen-resultaat');
}

function opnieuw() {
  document.querySelectorAll('.keuze-btn').forEach(b => b.className = 'keuze-btn');
  showScreen('screen-situatie');
}

function showScreen(id) {
  ['screen-situatie','screen-resultaat'].forEach(s => {
    const el = document.getElementById(s);
    el.classList.remove('active');
    el.style.display = 'none';
  });
  const el = document.getElementById(id);
  el.style.display = 'flex';
  el.classList.add('active');
}

applyLang();
showScreen('screen-situatie');
